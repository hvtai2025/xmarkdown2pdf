# Source (bundled by esbuild into dist/extension.js)
src/**
__mocks__/**
test/**
*.ts

# Build config
tsconfig.json
tsconfig.test.json
jest.config.js
esbuild.js

# Build artifacts (source maps)
dist/**/*.map

# Exclude all node_modules except the packages that are NOT bundled by esbuild.
# puppeteer and the markdown-it family are bundled into dist/extension.js, so
# only node-plantuml (and its direct deps) need to ship in the VSIX.
node_modules/**
!node_modules/node-plantuml/**
!node_modules/commander/**
!node_modules/node-nailgun-client/**
!node_modules/node-nailgun-server/**
!node_modules/plantuml-encoder/**

# media/libs JS files must ship; plantuml.jar is 28 MB and is downloaded at
# runtime by LibManager — do not include it in the VSIX.
media/libs/plantuml.jar

# Dev / CI
.github/**
coverage/**
.gitignore
.eslintrc*

# Documentation / samples (not needed at runtime)
ARCHITECTURE.html
ARCHITECTURE.md
requirements.md
requirements.pdf
sample.md
sample.html
sample.pdf
xmarkdown2pdf.code-workspace

# Packaging artifacts
*.vsix
.vscodeignore
