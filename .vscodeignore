# Source (bundled by esbuild into dist/extension.js)
src/**
__mocks__/**
test/**
*.ts

# Build config
tsconfig.json
tsconfig.test.json
jest.config.js
esbuild.js

# Build artifacts (source maps)
dist/**/*.map

# Keep runtime dependencies required by the extension (e.g. Puppeteer).
# VSCE already excludes devDependencies during packaging.

# Ensure bundled local libraries are always included in the VSIX.
!media/libs/**

# Dev / CI
.github/**
coverage/**
.gitignore
.eslintrc*

# Documentation / samples (not needed at runtime)
ARCHITECTURE.md
requirements.md
requirements.pdf
sample.md
sample.html
sample.pdf
xmarkdown2pdf.code-workspace

# Packaging artifacts
*.vsix
.vscodeignore
